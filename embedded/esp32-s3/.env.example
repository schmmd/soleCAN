# OPTIONAL build secrets. Without a .env, the firmware builds exactly as before
# (AP "tractor" / "electricity"). Copy this to `.env` (gitignored) only if you
# want to override those values:
#
#   cp .env.example .env
#   # generate a strong AP password (WPA2 requires 8-63 chars):
#   #   python3 -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(24)))"
#
# Source it before building:
#   native:  set -a; source .env; set +a; pio run -e lilygo_t2can
#   docker:  set -a; source .env; set +a; docker build -f embedded/esp32-s3/Dockerfile \
#              --build-arg AP_SSID="$AP_SSID" --build-arg AP_PASS="$AP_PASS" \
#              --build-arg WIFI_SSID="$WIFI_SSID" --build-arg WIFI_PASS="$WIFI_PASS" -t solectrac-fw .

# WiFi access point the board broadcasts (connect your phone/laptop to this in
# the field). Leave unset to keep the built-in defaults (tractor / electricity).
export AP_SSID="solectrac"
export AP_PASS="change-me-to-a-random-password"

# mDNS hostname the board advertises (reachable as <MDNS_NAME>.local). Leave
# unset to keep the default (tractor.local).
export MDNS_NAME="solectrac"

# Optional home network the board also joins for bench use. Leave empty for an
# AP-only build (the stable field default); the AP broadcasts regardless. Set
# both to also join a bench network.
export WIFI_SSID=""
export WIFI_PASS=""
