# Shared by all three Dockerfiles (root Python, esp32-s3, android).
# Universal excludes — VCS, build artifacts, secrets. Per-Dockerfile COPYs
# determine what actually ends up in each image; any extras here just keep
# the build-context tar smaller.
.git
**/.pio
**/__pycache__
*.log
out/
esp32-s3/.env

# Android-local artifacts (mirrors android/.gitignore). Keep the Android
# tree itself in context — android/Dockerfile copies it.
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/captures/
android/app/captures/
android/local.properties
android/gradle/wrapper/gradle-wrapper.jar
