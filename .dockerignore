# Keep the Docker build context small. Only the firmware project and the
# embedded dashboard asset are needed.
.git
**/.pio
**/__pycache__
*.log
out/
embedded/esp32-s3/.env

# Host-side Python tooling — not needed for the firmware build.
solecan-*.py
solecan_proto.py
util/
bms/
screenshot.svg

# Android-local artifacts (mirrors android/.gitignore). Keep the Android
# tree itself in context — android/Dockerfile copies it.
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/captures/
android/app/captures/
android/local.properties
android/gradle/wrapper/gradle-wrapper.jar
